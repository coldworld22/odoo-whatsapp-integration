<odoo>
    <record id="res_config_settings_view_form_inherit_whatsapp" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.whatsapp</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="WhatsApp" string="WhatsApp" name="skillbridge_whatsapp_cloud">
                    <block title="WhatsApp Business API" name="whatsapp_business_api">
                        <setting string="Access Token" help="Permanent Meta access token with whatsapp_business_messaging scope.">
                            <field name="whatsapp_token" placeholder="EAAJ..." password="True"/>
                        </setting>
                        <setting string="Phone Number ID" help="Numeric Meta phone_number_id from WhatsApp Manager, not the phone number itself.">
                            <field name="whatsapp_phone_number_id" placeholder="123456789012345"/>
                        </setting>
                        <setting string="Business Account ID" help="Numeric WhatsApp Business Account ID (WABA ID), required for template sync.">
                            <field name="whatsapp_business_account_id" placeholder="123456789012345"/>
                        </setting>
                        <setting string="Webhook Verify Token" help="Must match the value configured in the Meta webhook dashboard.">
                            <field name="whatsapp_webhook_verify_token" placeholder="my_verify_token"/>
                        </setting>
                        <setting string="App Secret" help="Used to validate X-Hub-Signature-256 headers on webhook callbacks.">
                            <field name="whatsapp_app_secret" password="True" placeholder="app secret"/>
                        </setting>
                        <setting string="Default Media URL" help="Fallback image URL for media sends. Use a public http:// or https:// URL.">
                            <field name="whatsapp_default_media_url" placeholder="https://.../image.jpg"/>
                        </setting>
                    </block>
                    <block title="Automation" name="whatsapp_automation">
                        <setting string="Sales Order Confirmation" help="Send a WhatsApp message with the sales order PDF when a quotation is confirmed.">
                            <field name="whatsapp_auto_send_on_confirm"/>
                        </setting>
                        <setting string="Invoice Posting" help="Send a WhatsApp message with sales order and invoice PDFs when an invoice is posted.">
                            <field name="whatsapp_auto_send_on_invoice_post"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
