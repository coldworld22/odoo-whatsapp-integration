<odoo>
    <record id="view_whatsapp_inbox_reply_form" model="ir.ui.view">
        <field name="name">whatsapp.inbox.reply.form</field>
        <field name="model">whatsapp.inbox.reply</field>
        <field name="arch" type="xml">
            <form string="Reply via WhatsApp">
                <group>
                    <field name="partner_id" readonly="1"/>
                    <field name="message_body" placeholder="Type your message..."/>
                </group>
                <footer>
                    <button name="action_send" type="object" string="Send" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
