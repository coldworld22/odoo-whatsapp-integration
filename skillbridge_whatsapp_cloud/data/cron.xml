<odoo>
    <record id="ir_cron_whatsapp_campaign" model="ir.cron">
        <field name="name">WhatsApp Campaign Batch</field>
        <field name="model_id" ref="model_whatsapp_campaign"/>
        <field name="state">code</field>
        <field name="code">model._cron_run_batch()</field>
        <field name="interval_number">10</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_whatsapp_template_sync" model="ir.cron">
        <field name="name">WhatsApp Template Sync</field>
        <field name="model_id" ref="model_whatsapp_template"/>
        <field name="state">code</field>
        <field name="code">model._cron_sync_from_meta()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>
</odoo>
